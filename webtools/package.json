{
  "name": "xray-toolbar",
  "version": "0.1.0",
  "private": true,
  "description": "XRay toolbar for browser automation annotations",
  "type": "module",
  "main": "dist/xray-toolbar.js",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/chroma-js": "^3.1.2",
    "@types/jest": "^30.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.50.1"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "chart.js": "^4.5.1",
    "chroma-js": "^3.2.0",
    "css-selector-generator": "^3.7.0",
    "html2canvas": "^1.4.1",
    "lucide": "^0.562.0"
  }
}
